# Provider selection: github | gemini | openai_compatible
MODEL_PROVIDER=github
MODEL_NAME=gpt-4o-mini

# GitHub Models settings
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODELS_TOKEN=replace_me
# token | gh_cli_sso
GITHUB_MODELS_AUTH_MODE=token
# Used only when GITHUB_MODELS_AUTH_MODE=gh_cli_sso
GITHUB_MODELS_TOKEN_COMMAND=gh auth token

# Gemini settings
GEMINI_API_KEY=replace_me

# OpenAI-compatible settings
OPENAI_COMPATIBLE_API_KEY=replace_me
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
